{
  "entities": {
    "Project": {
      "title": "Interactive Course",
      "description": "A structured interactive course or game",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "scenes": { 
          "type": "array",
          "items": { "$ref": "#/definitions/Scene" }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "playSettings": { "type": "object" }
      },
      "required": ["name", "scenes", "ownerId", "createdAt", "updatedAt", "playSettings"]
    },
    "Score": {
      "title": "Interaction Result",
      "description": "Result of a user interaction with a widget",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "sceneId": { "type": "string" },
        "type": { "type": "string" },
        "totalPairs": { "type": "number" },
        "correctPairs": { "type": "number" },
        "isCorrect": { "type": "boolean" },
        "selectedChoiceId": { "type": "string" },
        "timeSpent": { "type": "number" },
        "userId": { "type": "string" },
        "isTripleMatch": { "type": "boolean" },
        "playedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "sceneId", "playedAt"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Collection of interactive courses"
    },
    "scores": {
      "schema": "Score",
      "description": "Collection of user interaction results and quiz scores"
    }
  }
}
